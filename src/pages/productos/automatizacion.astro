---
import Nav_bar from "../../components/common/Navbar.astro";

import CategoryNav from '../../components/category/CategoryNav.astro';
import ProductCard from '../../components/category/ProductCard.astro';
import ContactForm from '../../components/common/ContactForm.astro';
import MainLayout from '../../layouts/MainLayout.astro';

import data from '../../data/automatizacion.json';

import hero_imagen from '../../assets/automatizacion/hero-imagen.png'
import plc from '../../assets/automatizacion/plc.png'
import refacciones from '../../assets/automatizacion/refacciones.png'
import elemento1 from '../../assets/elementos.png'


---

<MainLayout title="Automatización | Koonol MX">
    <Nav_bar />
    <img src={elemento1.src} alt="" class="h-15 md:h-35 absolute left-0 top-80 md:top-400">
    <img src={elemento1.src} alt="" class="h-15 md:h-35 absolute left-0 top-650 md:top-150">
    <img src={elemento1.src} alt="" class="h-15 md:h-35 absolute right-0 top-100 md:top-350">
    <img src={elemento1.src} alt="" class="h-15 md:h-35 absolute right-0 top-595 md:top-50">


    <main class="w-5/6 mx-auto  py-10">
        
        <!-- HERO -->
        <section>
            <div class="flex flex-col items-center md:items-start">
                <span class="w-full text-center md:text-start text-sm md:text-xl font-semibold text-principal">Soluciones de</span>
                <h1 class="text-5xl md:text-[17rem] font-semibold text-[#D7E6EB] tracking-tight leading-[0.75] ">AUTOMA</h1>
                <p class="w-full text-center md:text-end text-sm md:text-3xl font-semibold text-principal"> de Control y sistemas de IA</p>
            </div>

            <div class="flex flex-col justify-between items-center md:gap-15 md:flex-row mt-5 md:mt-0">
                <div class="md:h-50 md:border-l-2 border-gray-300 flex flex-col items-center text-center md:pl-5 md:items-start">
                    <!--Descripcion categoria -->
                    <p class="text-textos text-sm md:text-lg font-medium text-center mb-6 md:text-start">
                    {data.description}
                    </p>

                    <span class="text-principal text-xs md:text-lg font-medium max-w-md leading-relaxed mb-6">{data.brand}</span>
                    
                    <a
                        href="#contacto"
                        class="w-1/2 text-sm md:text-base text-center shadow-xl/20 bg-principal text-white font-medium py-3 rounded-full hover:bg-slate-800 transition-colors"
                        >
                        Contactanos
                    </a>
                </div>
                <img src={hero_imagen.src} alt="Telecom Hardware" class="w-full mt-5 md:w-1/2 md:mt-0" />
            </div>
        </section>

        <!-- Nav de categorias -->
        <CategoryNav active={data.activeCategory as any} />


        <section class="my-16">
            <div class="mb-8">
                <h2 class="text-xl md:text-4xl font-semibold text-principal">Productos Destacados</h2>
                <p class="text-xs md:text-base text-textos mt-4">
                    Equipos que optimizan y automatizan procesos industriales mediante tecnologías de control, monitoreo e inteligencia aplicada. 
                    Soluciones confiables para mejorar la productividad y eficiencia operativa.
                </p>
            </div>

            <!--CARDS de productos -->
            <div class="container-cards flex flex-col md:flex-row gap-4 w-full h-auto md:h-[400px] items-stretch">
                {data.products.map((product) => (
                    <ProductCard 
                        title={product.title}
                        tag={product.tag}
                        description={product.description}
                        image={product.image}
                        featured={product.featured}
                    />
                ))}
            </div>
        </section>

        <!--  -->
        <section class="flex flex-col items-center md:mt-20">
            <h1 class="text-xl md:text-3xl font-semibold text-principal md:mb-10 text-center">¿Necesitas otro componente industrial?</h1>
            <div class="flex flex-col md:flex-row items-center md:justify-center gap-5 md:gap-10 w-full">
                <div class="md:h-[500px] py-10 gap-5 w-full md:w-1/3 shadow-2xl rounded-xl flex flex-col items-center justify-center">
                    <h1 class="font-semibold text-lg md:text-2xl">PLC</h1>
                    <img src={plc.src} alt="" class="w-3/4">
                    <a href="#contacto" class="text-principal font-semibold py-3">Contactanos →</a>
                </div>
                <div class="md:h-[500px] py-10 gap-5 w-full md:w-1/3 shadow-2xl rounded-xl flex flex-col items-center justify-center">
                    <h1 class="font-semibold text-lg md:text-2xl">Refacciones</h1>
                    <img src={refacciones.src} alt="" class="w-3/4">
                    <a href="#contacto" class="text-principal font-semibold  py-3">Contactanos →</a>
                </div>
            </div>
            <p class="text-xs md:text-base text-textos mt-4 md:mt-10 text-justify md:text-center mb-5">Más de 2,500 SKUs disponibles, incluyendo PLC, HMI, variadores, sensores, relés, contactores, fuentes de alimentación, módulos de expansión y una amplia variedad de refacciones industriales para automatización y control.</p>
            <a href="#contacto" class=" text-sm md:text-base text-center shadow-xl/20 bg-principal text-white font-medium w-3/4 py-2 md:w-1/3 md:py-3 rounded-full hover:bg-slate-800 transition-colors">Consultar ahora</a>
        </section>

        <!-- CONTACTO -->
        <section id="contacto">
            <ContactForm />
        </section>

    </main>
</MainLayout>