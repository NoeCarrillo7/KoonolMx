---
import Nav_bar from "../../components/common/Navbar.astro";

import CategoryNav from '../../components/category/CategoryNav.astro';
import ProductCard from '../../components/category/ProductCard.astro';
import ContactForm from '../../components/common/ContactForm.astro';
import MainLayout from '../../layouts/MainLayout.astro';

import data from '../../data/refrigeracion.json';

import hero_imagen from '../../assets/refrigeracion/hero-imagen.png';
import impafri from '../../assets/refrigeracion/impafri.png';
import intarcon from '../../assets/refrigeracion/intarcon.png';
import infrico from '../../assets/refrigeracion/infrico.png';
import unox from '../../assets/refrigeracion/unox.png';
import elemento1 from '../../assets/elementos.png'


---

<MainLayout title="Refrigeración | Koonol MX">
    <Nav_bar />
    <img src={elemento1.src} alt="" class="h-15 md:h-35 absolute left-0 top-80 md:top-400">
    <img src={elemento1.src} alt="" class="h-15 md:h-35 absolute left-0 top-650 md:top-150">
    <img src={elemento1.src} alt="" class="h-15 md:h-35 absolute right-0 top-100 md:top-350">
    <img src={elemento1.src} alt="" class="h-15 md:h-35 absolute right-0 top-595 md:top-50">

    <main class="w-5/6 mx-auto  py-10">
        
        <!-- HERO -->
        <section>
            <div class="flex flex-col items-center md:items-start">
                <span class="w-full text-center md:text-start text-sm md:text-xl font-semibold text-principal">Soluciones de</span>
                <h1 class="text-5xl md:text-[17rem] font-semibold text-[#D7E6EB] tracking-tight leading-[0.75]">REFRIGER</h1>
                <p class="w-full text-center md:text-end text-sm md:text-3xl font-semibold text-principal">Industrial y Cocción Especializada</p>
            </div>

            <div class="flex flex-col justify-between items-center md:gap-15 md:flex-row mt-5 md:mt-0">
                <div class="md:h-50 md:border-l-2 border-gray-300 flex flex-col items-center text-center md:pl-5 md:items-start">
                    <!--Descripcion categoria -->
                    <p class="text-textos text-xs md:text-lg font-medium text-center mb-6 md:text-start">
                    {data.description}
                    </p>

                    <span class="text-principal text-sm md:text-lg font-medium max-w-md leading-relaxed mb-6">{data.brand}</span>
                    
                    <a
                        href="#contacto"
                        class="w-1/2 text-sm md:text-base text-center shadow-xl/20 bg-principal text-white font-medium py-3 rounded-full hover:bg-slate-800 transition-colors"
                        >
                        Contactanos
                    </a>
                </div>
                <img src={hero_imagen.src} alt="Telecom Hardware" class="w-full mt-5 md:w-1/2 md:mt-0" />
            </div>
        </section>

        <!-- Nav de categorias -->
        <CategoryNav active={data.activeCategory as any} />


        <section class="my-16">
            <div class="mb-8">
                <h2 class="text-xl md:text-4xl font-semibold text-principal text-center md:text-left">Soluciones IMPAFRI E INTARCON</h2>
                <p class="text-xs md:text-base text-textos text-justify md:text-left mt-4">
                    Soluciones modulares desmontables de alta densidad y aislamiento térmico optimizado. Diseñadas para una conservación eficiente, 
                    montaje rápido y adaptabilidad a espacios críticos en sectores comercial, hotelero e industrial.
                </p>
            </div>

            <!--CARDS de productos -->
            <div class="container-cards flex flex-col md:flex-row gap-4 w-full h-auto md:h-[400px] items-stretch">
                {data.products.map((product) => (
                <ProductCard 
                    title={product.title}
                    tag={product.tag}
                    description={product.description}
                    image={product.image}
                    featured={product.featured}
                />
                ))}
            </div>
        </section>

        <section class="flex flex-col items-center gap-5 md:gap-2">
            <p class="text-textos text-xs md:text-base text-justify md:text-center md:w-4/5 mb-5 md:mb-10">
                Te invitamos a explorar el catálogo completo de soluciones de alta tecnología de INFRICO e INTARCON. Encuentra el equipo exacto para tu sector y regresa con nosotros para gestionar tu cotización personalizada y soporte.
            </p>
            <div class="md:flex gap-10">
                <a href="https://impafri.com/" target="_blank">
                    <img src={impafri.src} alt="INFRICO" class="h-15 mx-auto mb-6 object-contain" />
                </a>
                <a href="https://www.intarcon.com/" target="_blank">
                    <img src={intarcon.src} alt="INTARCON" class="h-15 mx-auto mb-6 object-contain" />
                </a>
            </div>
        </section>

        <section class="my-16">
            <div class="mb-8">
                <h2 class="text-xl md:text-4xl font-semibold text-principal text-center md:text-left">Soluciones INFRICO</h2>
                <p class="text-xs md:text-base text-textos text-justify md:text-left mt-4">
                    Equipamiento profesional para cocinas comerciales e industriales que garantiza un alto desempeño, eficiencia energética y conservación óptima de alimentos.
                </p>
            </div>

            <!--CARDS de productos -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {data.products2.map((product) => (
                <ProductCard 
                    title={product.title}
                    tag={product.tag}
                    description={product.description}
                    image={product.image}
                    featured={product.featured}
                />
                ))}
            </div>
        </section>

        <section class="flex flex-col items-center gap-5 md:gap-2">
            <p class="text-textos text-xs md:text-base text-justify md:text-center md:w-4/5 mb-5 md:mb-10">
                Explora la gama completa de soluciones médicas y de abatimiento en la web oficial de INFRICO. Elige tus equipos y regresa a nuestra sección de contacto para solicitar tu presupuesto personalizado.
            </p>
            <div>
                <a href="https://infrico.com/" target="_blank">
                    <img src={infrico.src} alt="INFRICO" class="h-15 mx-auto mb-6 object-contain" />
                </a>
            </div>
        </section>

        <section class="flex flex-col md:flex-row justify-center items-center mt-10">
            <div class=" w-full md:w-1/3 shadow-xl flex flex-col justify-center items-center text-center">
                <img src={unox.src} alt="">
                <span>Sistemas de Cocción Avanzada</span>
                <h2>Hornos Inteligentes UNOX</h2>
                <p>Tecnología global en hornos combinados y de convección diseñados para maximizar el rendimiento en cocinas profesionales, panaderías y pastelerías.</p>
            </div>
            <div class="bg-principal py-5 w-full md:w-2/4 flex flex-col justify-center items-center text-center">
                <h1>Más soluciones para tu operación</h1>
                <p>Además de nuestra infraestructura en refrigeración comercial e industrial, somos distribuidores autorizados de UNOX, líderes mundiales en hornos combinados inteligentes.</p>
                <a href="">Explora tecnología UNOX</a>
            </div>
        </section>

        <!-- CONTACTO -->
        <section id="contacto">
            <ContactForm />
        </section>

    </main>
</MainLayout>